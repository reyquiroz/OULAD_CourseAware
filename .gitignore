# Keep processed data and results
!data/processed/
!results/

# Keep important result CSVs
!results/**/*.csv
!output_results/**/*.csv

# Keep important visualizations (results)
!results/**/*.png
!results/**/*.jpg
!results/**/*.pdf

# Exclude large intermediate outputs
output_results/*.png
output_results/*.jpg

